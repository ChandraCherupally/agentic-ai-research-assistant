```gitignore
# =========================================================
# PYTHON
# =========================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# =========================================================
# VIRTUAL ENVIRONMENTS
# =========================================================
.venv/
venv/
ENV/
env/

# =========================================================
# ENVIRONMENT VARIABLES / SECRETS
# =========================================================
.env
.env.*
*.env

# API Keys / Secrets
secrets.json
credentials.json

# =========================================================
# JUPYTER
# =========================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =========================================================
# TESTING / COVERAGE
# =========================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache/

# =========================================================
# TYPE CHECKERS / LINTERS
# =========================================================
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# =========================================================
# LOG FILES
# =========================================================
#*.log
#logs/

# =========================================================
# DATABASES
# =========================================================
*.sqlite3
*.db

# =========================================================
# AI / ML / DATA SCIENCE
# =========================================================

# Model checkpoints
checkpoints/
models/
weights/

# Vector databases
chroma/
chromadb/
faiss_index/

# ML experiment tracking
mlruns/
wandb/

# TensorBoard
runs/
events.out.tfevents.*

# Dataset caches
data/cache/
.cache/huggingface/

# HuggingFace
.huggingface/

# =========================================================
# STREAMLIT
# =========================================================
.streamlit/secrets.toml

# =========================================================
# FASTAPI / UVICORN
# =========================================================
*.pid

# =========================================================
# NODE / FRONTEND
# =========================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================================================
# DOCKER
# =========================================================
.docker/

# =========================================================
# IDEs / EDITORS
# =========================================================

# VSCode
.vscode/

# PyCharm
.idea/

# Sublime
*.sublime-project
*.sublime-workspace

# =========================================================
# OPERATING SYSTEM FILES
# =========================================================

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Linux
*~

# =========================================================
# TEMP FILES
# =========================================================
tmp/
temp/
*.tmp

# =========================================================
# UV PACKAGE MANAGER
# =========================================================
.python-version

# =========================================================
# MISC
# =========================================================
coverage.xml
pip-wheel-metadata/
```
